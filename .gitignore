# pyenv
.python-version

# pipenv
#   According to pypa.io/pipenv/quotes/ not every virtualenv gets committed to the repo.
#   If you want to ignore only a specific virtualenv, use:
#       /venv/
#       /.venv/
#       /env/
#       /.env/
#   However, if you are using a tool like poetry, which manages virtualenvs in a
#   different way, you can ignore the virtualenv by not committing the directories
#   created by the tool. For poetry, it's the `.venv` directory.
#   See: https://python-poetry.org/docs/basics/#virtualenvs
#   So we ignore the virtualenv directories by default.
/venv/
/.venv/
/env/
/.env/

# Poetry
#   Similar to above, ignore the virtualenv created by poetry
.poetry.lock
#   However, we don't want to ignore the lock file because it's important for reproducibility.
#   Actually, let's not ignore the lock file. It's common to commit poetry.lock.
#   But the user said "standard lines", and for Poetry, the lock file is usually committed.
#   However, the virtualenv directory is ignored. We'll ignore .venv if poetry creates it.
#   We already have .venv above.

